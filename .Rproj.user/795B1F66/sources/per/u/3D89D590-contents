# SECTION 3: Formal Normality Testing
shapiro_test <- shapiro.test(spy_returns_df$Returns)
cat("Shapiro-Wilk Test:\n")
print(shapiro_test)

ad_test <- ad.test(spy_returns_df$Returns)
cat("Anderson-Darling Test:\n")
print(ad_test)

ks_test <- ks.test(
  spy_returns_df$Returns,
  "pnorm",
  mean = mean(spy_returns_df$Returns, na.rm = TRUE),
  sd = sd(spy_returns_df$Returns, na.rm = TRUE)
)
cat("Kolmogorov-Smirnov Test:\n")
print(ks_test)

jb_test <- jarque.bera.test(spy_returns_df$Returns)
cat("Jarque-Bera Test:\n")
print(jb_test)

