# SECTION 8: CAPM - Estimating Beta and Alpha for Multiple Assets
tickers <- c("AAPL", "MSFT", "TSLA", "KO", "XOM")
getSymbols(tickers, src = "yahoo", from = "2015-01-01", to = Sys.Date())

asset_returns_list <- lapply(tickers, function(tkr) {
  px <- Ad(get(tkr))
  ret <- dailyReturn(px, type = "log")
  colnames(ret) <- tkr
  ret
})
asset_returns <- do.call(merge, asset_returns_list)

market_returns <- spy_returns
colnames(market_returns) <- "SPY"

all_returns <- na.omit(merge(asset_returns, market_returns))

estimate_capm <- function(asset_name, data) {
  df <- data.frame(
    asset = as.numeric(data[, asset_name][, 1]),
    market = as.numeric(data[, "SPY"][, 1])
  )
  
  model <- lm(asset ~ market, data = df)
  
  alpha_daily <- coef(model)[1]
  beta <- coef(model)[2]
  
  avg_asset_return_daily <- mean(df$asset, na.rm = TRUE)
  avg_market_return_daily <- mean(df$market, na.rm = TRUE)
  
  capm_expected_daily <- beta * avg_market_return_daily
  capm_gap_daily <- avg_asset_return_daily - capm_expected_daily
  
  data.frame(
    Asset = asset_name,
    Alpha_Daily = alpha_daily,
    Beta = beta,
    Avg_Return_Daily = avg_asset_return_daily,
    Market_Return_Daily = avg_market_return_daily,
    CAPM_Predicted_Daily = capm_expected_daily,
    Gap_Actual_minus_CAPM = capm_gap_daily,
    R_squared = summary(model)$r.squared
  )
}

capm_results <- do.call(rbind, lapply(tickers, estimate_capm, data = all_returns))

capm_results <- capm_results %>%
  mutate(
    Alpha_Annualized = Alpha_Daily * 252,
    Avg_Return_Annualized = Avg_Return_Daily * 252,
    CAPM_Predicted_Annualized = CAPM_Predicted_Daily * 252,
    Gap_Annualized = Gap_Actual_minus_CAPM * 252
  )

cat("\nCAPM RESULTS:\n")
print(capm_results)

# ------------------------------------------------------------------
# SECTION 9: Visualizing CAPM Results
ggplot(capm_results, aes(x = Beta, y = Avg_Return_Annualized, label = Asset)) +
  geom_point(size = 3, color = "blue") +
  geom_text(nudge_y = 0.01) +
  geom_abline(
    intercept = 0,
    slope = mean(as.numeric(all_returns[, "SPY"]), na.rm = TRUE) * 252,
    linetype = "dashed",
    color = "red"
  ) +
  labs(title = "Average Return vs Beta", x = "Estimated Beta", y = "Annualized Average Return") +
  theme_minimal()

ggplot(capm_results, aes(x = Asset, y = Alpha_Annualized, fill = Asset)) +
  geom_bar(stat = "identity") +
  labs(title = "Estimated Annualized Alpha by Asset", x = "Asset", y = "Annualized Alpha") +
  theme_minimal() +
  theme(legend.position = "none")

