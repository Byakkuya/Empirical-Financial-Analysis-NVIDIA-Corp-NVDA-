# SECTION 4: Discussion of Non-Normal Returns
skewness_val <- skewness(spy_returns_df$Returns, na.rm = TRUE)
kurtosis_val <- kurtosis(spy_returns_df$Returns, na.rm = TRUE)
cat("Skewness:", skewness_val, "\n")
cat("Kurtosis:", kurtosis_val, "\n")
if (abs(skewness_val) > 0.5) cat("The distribution is skewed.\n")
if (kurtosis_val > 3) cat("The distribution has heavy tails.\n")

# ------------------------------------------------------------------
# SECTION 5: Dealing with Non-Normality
spy_simple_returns <- dailyReturn(spy_prices, type = "arithmetic")
colnames(spy_simple_returns) <- "Returns"
spy_simple_df <- data.frame(
  Date = index(spy_simple_returns),
  Returns = coredata(spy_simple_returns)
)

sqrt_returns <- sqrt(abs(spy_simple_df$Returns)) * sign(spy_simple_df$Returns)
log_transformed <- log(1 + spy_simple_df$Returns)

transformed_df <- data.frame(
  Original = spy_simple_df$Returns,
  Sqrt = sqrt_returns,
  Log = log_transformed
)

long_df <- pivot_longer(
  transformed_df,
  everything(),
  names_to = "Type",
  values_to = "Return"
)

ggplot(long_df, aes(x = Return, fill = Type)) +
  geom_histogram(aes(y = ..density..), bins = 30, alpha = 0.4, position = "identity") +
  facet_wrap(~Type, scales = "free") +
  labs(title = "Distributions: Original vs Sqrt vs Log", x = "Return", y = "Density") +
  theme_minimal()

pre_covid <- spy_returns_df$Returns[spy_returns_df$Date < as.Date("2020-03-01")]
post_covid <- spy_returns_df$Returns[spy_returns_df$Date >= as.Date("2020-03-01")]

wilcox_test <- wilcox.test(pre_covid, post_covid, alternative = "two.sided")
cat("Wilcoxon Test:\n")
print(wilcox_test)

