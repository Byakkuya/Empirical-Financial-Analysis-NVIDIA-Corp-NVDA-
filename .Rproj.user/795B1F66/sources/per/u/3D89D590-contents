# SECTION 11: A Simple Zero-Beta / Arbitrage-Style Portfolio
beta_tsla <- capm_results$Beta[capm_results$Asset == "TSLA"]
beta_ko <- capm_results$Beta[capm_results$Asset == "KO"]

w_tsla <- 1
w_ko <- -beta_tsla / beta_ko

cat("\nZERO-BETA PORTFOLIO WEIGHTS:\n")
cat("TSLA weight:", w_tsla, "\n")
cat("KO weight:", w_ko, "\n")

port_returns <- w_tsla * all_returns[, "TSLA"] + w_ko * all_returns[, "KO"]
colnames(port_returns) <- "ZeroBeta"

port_df <- data.frame(
  port = as.numeric(port_returns[, 1]),
  market = as.numeric(all_returns[, "SPY"][, 1])
)

port_model <- lm(port ~ market, data = port_df)

cat("\nZERO-BETA PORTFOLIO REGRESSION:\n")
print(summary(port_model))

cat("\nAverage daily return of zero-beta portfolio:\n")
print(mean(port_df$port, na.rm = TRUE))

cat("\nAnnualized average return of zero-beta portfolio:\n")
