# SECTION 6: Risk Measures: VaR and Expected Shortfall
confidence_level <- 0.95
VaR <- quantile(spy_returns_df$Returns, probs = 1 - confidence_level, na.rm = TRUE)
ES <- mean(spy_returns_df$Returns[spy_returns_df$Returns <= VaR], na.rm = TRUE)
cat("Value at Risk (95%):", VaR, "\n")
cat("Expected Shortfall (95%):", ES, "\n")

p4 <- ggplot(data = spy_returns_df, aes(x = Returns)) +
  geom_histogram(aes(y = ..density..), bins = 30, fill = "grey", alpha = 0.5) +
  geom_vline(xintercept = VaR, color = "red", linetype = "dashed", size = 1) +
  labs(title = "Histogram of SPY Returns with VaR", x = "Return", y = "Density") +
  theme_minimal()
print(p4)

